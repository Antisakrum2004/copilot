  "quick_facts": {
    "audio_format_target": "PCM 16000Hz, 1 channel, 16-bit (s16le)",
    "mic_capture_strategy": "Renderer-side via navigator.mediaDevices.getUserMedia (Chromium AudioContext + ScriptProcessorNode)",
    "system_capture_strategy": "Main-side via WinAudioCapture (WASAPI Loopback), fallback ffmpeg dshow/avfoundation/alsa",
    "overlay_trick": "Clickthrough windows via #02000000 background color + setIgnoreMouseEvents(true, {forward: true}) + mouseenter/mouseleave toggle",
    "ipc_bridge": "contextBridge.exposeInMainWorld('copilot') → window.copilot.audio.sendMicChunk(ArrayBuffer) → ipcRenderer.send → ipcMain.on",
    "chunk_size": "6 seconds = 192 000 bytes (16000 Hz × 16 bit × 1 ch × 6 s)",
    "whisper_model_groq": "whisper-large-v3",
