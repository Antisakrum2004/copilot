{
  "name": "shadowhint",
  "version": "0.1.134",
  "description": "ShadowHint - Intelligent AI assistant for job interview preparation and career development",
  "main": ".webpack/main",
  "homepage": "https://github.com/Pomau/ai-assistant-front",
  "author": {
    "name": "ShadowHint",
    "email": "help@shadowhint.com",
    "url": "https://shadowhint.com"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Pomau/ai-assistant-front.git"
  },
  "bugs": {
    "url": "https://github.com/Pomau/ai-assistant-front/issues"
  },
  "scripts": {
    "postinstall": "patch-package",
    "configure:shadowhint": "node scripts/configure-variant.js shadowhint",
    "configure:deskhint": "node scripts/configure-variant.js deskhint",
    "configure:exameasy": "node scripts/configure-variant.js exameasy",
    "configure:psykit": "node scripts/configure-variant.js psykit",
    "start": "node ./node_modules/@electron-forge/cli/dist/electron-forge.js start",
    "dev": "node ./node_modules/@electron-forge/cli/dist/electron-forge.js start",
    "dev:debug": "cross-env NODE_ENV=development node ./node_modules/@electron-forge/cli/dist/electron-forge.js start -- --inspect=5858 --remote-debugging-port=9222",
    "dev:shadowhint": "npm run configure:shadowhint && npm run dev",
    "dev:deskhint": "npm run configure:deskhint && npm run dev",
    "dev:exameasy": "npm run configure:exameasy && npm run dev",
    "dev:psykit": "npm run configure:psykit && npm run dev",
    "package": "node ./node_modules/@electron-forge/cli/dist/electron-forge.js package",
    "premake": "npm run prepare:native",
    "make": "node ./node_modules/@electron-forge/cli/dist/electron-forge.js make",
    "make:shadowhint": "npm run configure:shadowhint && npm run make",
    "make:deskhint": "npm run configure:deskhint && npm run make",
    "make:exameasy": "npm run configure:exameasy && npm run make",
    "make:psykit": "npm run configure:psykit && npm run make",
    "make:universal": "node scripts/build-universal.js",
    "make:universal:dmg": "node scripts/create-dmg.js",
    "make:universal:builder": "node scripts/build-with-electron-builder.js",
    "sign:universal": "node scripts/sign-universal.js",
    "notarize:ci": "node scripts/notarize-ci.js",
    "publish": "node ./node_modules/@electron-forge/cli/dist/electron-forge.js publish",
    "lint": "eslint .",
    "test": "vitest --run",
    "test:watch": "vitest",
    "prepare:native": "echo 'Native modules are no longer needed - using electron-audio-loopback'",
    "update-version": "node -e \"const fs = require('fs'); const { execSync } = require('child_process'); try { const tag = execSync('git describe --tags --abbrev=0', { encoding: 'utf8' }).trim(); const version = tag.startsWith('v') ? tag.slice(1) : tag; const pkg = JSON.parse(fs.readFileSync('package.json', 'utf8')); console.log('Обновляю версию с', pkg.version, 'на', version); pkg.version = version; fs.writeFileSync('package.json', JSON.stringify(pkg, null, '\\t')); console.log('Версия успешно обновлена!'); } catch (e) { console.log('Git теги не найдены, оставляю текущую версию'); }\"",
    "generate-protos": "grpc_tools_node_protoc --js_out=import_style=commonjs,binary:./generated --grpc_out=grpc_js:./generated --proto_path=./proto ./proto/google/protobuf/timestamp.proto ./proto/google/protobuf/empty.proto ./proto/google/protobuf/duration.proto ./proto/validate/validate.proto ./proto/interview/interview.proto",
    "protos": "node -e \"const fs = require('fs'); const path = './generated'; if (!fs.existsSync(path)) fs.mkdirSync(path, { recursive: true });\" && npm run generate-protos",
    "generate-ts-win": "node -e \"const fs = require('fs'); const path = './src/@types/generated'; if (!fs.existsSync(path)) fs.mkdirSync(path, { recursive: true });\" && .\\node_modules\\.bin\\grpc_tools_node_protoc.cmd --plugin=protoc-gen-ts_proto=.\\node_modules\\.bin\\protoc-gen-ts_proto.cmd --ts_proto_out=./src/@types/generated --ts_proto_opt=esModuleInterop=true,outputClientImpl=grpc-web,useDate=true,outputServices=grpc-js --proto_path=./proto ./proto/interview/interview.proto ./proto/google/protobuf/timestamp.proto ./proto/google/protobuf/empty.proto ./proto/google/protobuf/duration.proto ./proto/validate/validate.proto ./proto/google/api/annotations.proto ./proto/google/api/http.proto",
    "generate-ts": "node -e \"const fs = require('fs'); const path = './src/@types/generated'; if (!fs.existsSync(path)) fs.mkdirSync(path, { recursive: true });\" && ./node_modules/.bin/grpc_tools_node_protoc --plugin=protoc-gen-ts_proto=./node_modules/.bin/protoc-gen-ts_proto --ts_proto_out=./src/@types/generated --ts_proto_opt=outputServices=grpc-js --ts_proto_opt=esModuleInterop=true --ts_proto_opt=useDate=true -I./proto ./proto/interview/interview.proto ./proto/google/protobuf/timestamp.proto ./proto/google/protobuf/empty.proto ./proto/google/protobuf/duration.proto ./proto/validate/validate.proto ./proto/google/api/annotations.proto ./proto/google/api/http.proto",
    "generate-interview": "node scripts/fast-interview-gen.js",
    "generate-fast": "node scripts/fast-interview-gen.js",
    "generate-minimal": "node scripts/minimal-interview-gen.js",
    "fix-imports": "node -e \"console.log('Импорты исправлены успешно')\"",
    "create-icons": "node -e \"const pngToIco = require('png-to-ico'); const fs = require('fs'); pngToIco('logo.png').then(buf => { fs.writeFileSync('assets/icon.ico', buf); console.log('Icons created successfully!'); }).catch(console.error);\"",
    "build:nsis": "electron-builder --win --x64",
    "build:all": "electron-builder --win --x64 --publish=never"
  },
  "keywords": [
    "electron",
    "react",
    "typescript",
    "interview",
    "assistant",
    "ai",
    "artificial intelligence",
    "job preparation",
    "career",
    "hr tools"
  ],
  "devDependencies": {
    "@electron-forge/cli": "^7.2.0",
    "@electron-forge/maker-deb": "^7.2.0",
    "@electron-forge/maker-dmg": "^7.8.1",
    "@electron-forge/maker-rpm": "^7.2.0",
    "@electron-forge/maker-squirrel": "^7.2.0",
    "@electron-forge/maker-zip": "^7.2.0",
    "@electron-forge/plugin-auto-unpack-natives": "^7.2.0",
    "@electron-forge/plugin-webpack": "^7.10.2",
    "@electron-forge/publisher-github": "^7.8.1",
    "@electron/notarize": "^2.5.0",
    "@electron/universal": "^2.0.3",
    "@eslint/js": "^8.56.0",
    "@felixrieseberg/electron-forge-maker-nsis": "^7.2.0",
    "@grpc/proto-loader": "^0.7.15",
    "@modelcontextprotocol/sdk": "^1.15.0",
    "@playwright/test": "^1.53.2",
    "@sentry/webpack-plugin": "^5.1.1",
    "@types/google-protobuf": "^3.15.12",
    "@types/jsdom": "^27.0.0",
    "@types/katex": "^0.16.7",
    "@types/node": "^20.10.5",
    "@types/prismjs": "^1.26.5",
    "@types/react": "^18.2.45",
    "@types/react-dom": "^18.2.18",
    "@types/react-katex": "^3.0.4",
    "@types/uuid": "^10.0.0",
    "@types/winston": "^2.4.4",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "@vercel/webpack-asset-relocator-loader": "^1.7.3",
    "@vitest/ui": "^4.0.16",
    "app-builder-bin": "^4.2.0",
    "babel-runtime": "^6.26.0",
    "cross-env": "^7.0.3",
    "css-loader": "^6.8.1",
    "dotenv-webpack": "^8.1.1",
    "electron": "^31.7.7",
    "electron-builder": "^26.0.12",
    "electron-debug-mcp": "github:amafjarkasi/electron-mcp-server",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^10.1.2",
    "eslint-import-resolver-typescript": "^4.3.4",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.33.2",
    "eslint-plugin-react-hooks": "^4.6.0",
    "file-loader": "^6.2.0",
    "fork-ts-checker-webpack-plugin": "^9.0.2",
    "globals": "^16.0.0",
    "grpc-tools": "^1.13.0",
    "highlight.js": "^11.11.1",
    "jsdom": "^27.4.0",
    "node-gyp": "^11.2.0",
    "node-loader": "^2.0.0",
    "patch-package": "^8.0.1",
    "pe-library": "^2.0.1",
    "playwright": "^1.53.2",
    "png-to-ico": "^2.1.8",
    "prettier": "^3.5.3",
    "prismjs": "^1.30.0",
    "resedit": "^3.0.2",
    "robotjs": "^0.6.0",
    "screenshot-desktop": "^1.15.1",
    "style-loader": "^3.3.3",
    "ts-loader": "^9.5.1",
    "ts-node": "^10.9.2",
    "ts-proto": "^2.7.2",
    "typescript": "~5.3.3",
    "typescript-eslint": "^0.0.1-alpha.0",
    "vitest": "^4.0.16",
    "webpack-cli": "^6.0.1"
  },
  "dependencies": {
    "@grpc/grpc-js": "^1.13.3",
    "@sentry/electron": "^6.8.0",
    "@sentry/profiling-node": "^9.47.1",
    "@statsig/js-client": "^3.31.0",
    "@statsig/session-replay": "^3.31.0",
    "@statsig/web-analytics": "^3.31.0",
    "cors": "^2.8.5",
    "electron-audio-loopback": "^1.0.3",
    "electron-squirrel-startup": "^1.0.0",
    "electron-store": "^8.2.0",
    "electron-updater": "^6.6.2",
    "express": "^5.1.0",
    "ffmpeg-static": "^5.3.0",
    "google-protobuf": "^3.21.4",
    "http-proxy-middleware": "^3.0.5",
    "i18next": "^25.3.6",
    "jsonwebtoken": "^9.0.2",
    "katex": "^0.16.27",
    "koffi": "^2.15.1",
    "naudiodon": "^2.3.6",
    "node-machine-id": "^1.1.12",
    "opusscript": "^0.1.1",
    "rcedit": "^4.0.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-i18next": "^15.6.1",
    "react-katex": "^3.1.0",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^6.21.0",
    "react-virtuoso": "^4.13.0",
    "remark-gfm": "^4.0.1",
    "systeminformation": "^5.27.10",
    "use-resize-observer": "^9.1.0",
    "win-audio-capture": "^1.0.1",
    "winston": "^3.17.0",
    "winston-loki": "^6.1.3"
  },
  "build": {
    "appId": "com.shadowhint.assistant",
    "productName": "ShadowHint",
    "copyright": "Copyright © 2024 ShadowHint",
    "directories": {
      "output": "dist"
    },
    "files": [
      ".webpack/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "extraMetadata": {
      "name": "shadowhint",
      "main": ".webpack/main"
    },
    "win": {
      "verifyUpdateCodeSignature": false,
      "publisherName": "ShadowHint",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.ico",
      "artifactName": "${productName}-${version}-${arch}.${ext}",
      "requestedExecutionLevel": "asInvoker",
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": true,
      "allowToChangeInstallationDirectory": false,
      "perMachine": false,
      "allowElevation": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "ShadowHint",
      "runAfterFinish": true,
      "installerLanguages": [
        "ru",
        "en"
      ],
      "include": "build/installer.nsh",
      "warningsAsErrors": false
    },
    "publish": {
      "provider": "github",
      "owner": "Pomau",
      "repo": "ai-assistant-front"
    }
  }
}
